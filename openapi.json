{
  "openapi": "3.0.1",
  "info": {
    "title": "ReadPoint Reader Service API",
    "description": "일반 독자용 도서 정보 조회 및 Neo4j 인물 관계 데이터 조회 API 명세",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://<your-reader-service-function-app>.azurewebsites.net/api",
      "description": "배포된 Reader Service Azure Function App 주소"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "독자 권한의 JWT 토큰을 Bearer 헤더에 추가하세요."
      }
    }
  },
  "paths": {
    "/books": {
      "get": {
        "summary": "분석이 완료된 도서 목록 조회",
        "description": "상태가 COMPLETE인 모든 도서 목록을 최신순으로 조회합니다.",
        "responses": {
          "200": {
            "description": "도서 목록 조회 완료"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "summary": "단일 도서 정보 조회",
        "description": "도서 고유 식별자(ID)를 기준으로 단일 도서 정보를 조회합니다.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "도서 조회 성공"
          },
          "400": {
            "description": "잘못된 식별자 형식"
          },
          "404": {
            "description": "존재하지 않는 도서"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/books/{bookId}/relations": {
      "get": {
        "summary": "도서 인물 관계 데이터(Neo4j) 조회",
        "description": "도서 식별자와 특정 문단 시점(p)을 입력받아, 그 시점까지의 인물 노드와 엣지 관계망 정보를 조회합니다. 결과는 캐시될 수 있습니다.",
        "parameters": [
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "c",
            "in": "query",
            "required": false,
            "description": "챕터 시점 (1 이상의 정수, 기본값: 1)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "p",
            "in": "query",
            "required": false,
            "description": "문단 시점 (0 이상의 정수, 기본값: 1)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "인물 관계망 데이터 반환 완료"
          },
          "400": {
            "description": "잘못된 파라미터 규격"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/books/{bookId}/chapters": {
      "get": {
        "summary": "도서별 챕터 목록 조회",
        "description": "특정 도서의 전체 챕터 번호 및 챕터명 목록을 정렬된 순서(chapter_order ASC)로 반환합니다. 일반 독자용 API로 별도의 인증 토큰이 필요하지 않습니다.",
        "parameters": [
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "챕터 목록 반환 완료"
          },
          "400": {
            "description": "잘못된 파라미터 규격"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/books/{bookId}/summary": {
      "get": {
        "summary": "도서 실시간 전체 줄거리 요약 조회",
        "description": "독자의 현재 진행 시점(chapter_id, end_paragraph_id)을 기준으로, 해당 시점 이하에서 가장 최신의 3줄 줄거리 요약 1개를 조회합니다. chapter_id 대신 c, end_paragraph_id 대신 p 요약 파라미터를 사용할 수 있습니다.",
        "parameters": [
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "chapter_id",
            "in": "query",
            "required": false,
            "description": "챕터 고유 식별자",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "c",
            "in": "query",
            "required": false,
            "description": "챕터 고유 식별자 (chapter_id의 요약어)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "end_paragraph_id",
            "in": "query",
            "required": false,
            "description": "문단 고유 식별자",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "p",
            "in": "query",
            "required": false,
            "description": "문단 고유 식별자 (end_paragraph_id의 요약어)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "요약 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "string",
                      "nullable": true,
                      "description": "3줄 요약 텍스트 (해당 시점 이전에 요약이 존재하지 않는 경우 null)"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 파라미터 규격 또는 유효하지 않은 독서 시점"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/books/{bookId}/progress": {
      "get": {
        "summary": "독서 진도 조회",
        "description": "사용자의 해당 도서에 대한 마지막 독서 진도(챕터 및 문단 번호)를 조회합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "진도 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "progress": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "id": { "type": "integer" },
                        "user_id": { "type": "integer" },
                        "book_id": { "type": "integer" },
                        "chapter_id": { "type": "integer" },
                        "chapter_order": { "type": "integer" },
                        "last_read_paragraph_id": { "type": "integer" },
                        "paragraph_order": { "type": "integer" },
                        "created_at": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "인증 토큰 누락"
          },
          "403": {
            "description": "유효하지 않은 토큰"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      },
      "post": {
        "summary": "독서 진도 저장/갱신",
        "description": "실제 책의 챕터 번호 및 문단 번호를 입력받아 해당 사용자의 독서 진도를 저장하거나 최신 위치로 갱신(UPSERT)합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "도서 식별자",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "chapter_order": {
                    "type": "integer",
                    "description": "실제 책의 챕터 번호"
                  },
                  "paragraph_order": {
                    "type": "integer",
                    "description": "실제 책의 문단 번호"
                  }
                },
                "required": [
                  "chapter_order",
                  "paragraph_order"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "진도 갱신 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "progress": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "user_id": { "type": "integer" },
                        "book_id": { "type": "integer" },
                        "chapter_id": { "type": "integer" },
                        "chapter_order": { "type": "integer" },
                        "last_read_paragraph_id": { "type": "integer" },
                        "paragraph_order": { "type": "integer" },
                        "created_at": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 파라미터 규격 또는 존재하지 않는 챕터/문단 번호"
          },
          "401": {
            "description": "인증 토큰 누락"
          },
          "403": {
            "description": "유효하지 않은 토큰"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    }
  }
}

